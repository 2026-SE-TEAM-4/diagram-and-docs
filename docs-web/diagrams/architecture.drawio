        <mxCell id="cicd" value="CI / CD 파이프라인" style="rounded=1;verticalAlign=top;fontStyle=1;fontSize=12;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;" vertex="1" parent="1">
